# =============================================================================
# VRINDAVAN BHANDARA — ENVIRONMENT VARIABLES
# =============================================================================
# Copy to .env / .env.local. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# NEXT.JS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Vrindavan Bhandara"
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE — Supabase PostgreSQL (Prisma)
# Settings → Database → Connection string
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# SUPABASE — Auth + Storage (+ same project as DB)
# Settings → API Keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-or-secret-key

# Optional aliases (newer Supabase dashboard names)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# -----------------------------------------------------------------------------
# GOOGLE OAUTH — configure in Supabase Auth → Providers → Google
# (App no longer uses NextAuth; set redirect URLs in Supabase + Google Cloud)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET are set in the Supabase dashboard,
# not required in this file unless you keep them for reference.

# -----------------------------------------------------------------------------
# PAYMENTS — Razorpay
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# EMAIL — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=seva@vrindavanbhandara.com
RESEND_FROM_NAME="Vrindavan Bhandara"

# -----------------------------------------------------------------------------
# WHATSAPP — Meta Cloud API
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-whatsapp-webhook-verify-token
WHATSAPP_API_VERSION=v19.0
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=+919999999999

# -----------------------------------------------------------------------------
# OPTIONAL — Sentry / PostHog / Upstash
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# SEED ADMIN (prisma db seed)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@vrindavanbhandara.com
SEED_ADMIN_PASSWORD=ChangeMe@123!

# -----------------------------------------------------------------------------
# SEO
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Vrindavan Bhandara"
NEXT_PUBLIC_OG_IMAGE=http://localhost:3000/og-image.jpg

CRON_SECRET=your-internal-cron-secret

NEXT_PUBLIC_FEATURE_REFERRAL=false
NEXT_PUBLIC_FEATURE_COUPONS=false
NEXT_PUBLIC_FEATURE_SUBSCRIPTIONS=false
NEXT_PUBLIC_FEATURE_WHATSAPP_LIVE=false
