# =============================================================================
# VRINDAVAN BHANDARA — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local development.
# Never commit .env.local to version control.
# All values marked [REQUIRED] must be set before the app will start.
# =============================================================================

# -----------------------------------------------------------------------------
# NEXT.JS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://vrindavanbhandara.com
NEXT_PUBLIC_APP_NAME="Vrindavan Bhandara"
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE — Supabase PostgreSQL
# Docs: https://supabase.com/docs/guides/database/connecting-to-postgres
# Project Settings → Database → Connection string (URI, Session pooler for app)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"  # [REQUIRED]
# Direct connection (migrations / db push) — port 5432, not the pooler
DATABASE_URL_UNPOOLED="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# AUTHENTICATION — NextAuth v5
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000                    # Change for production
NEXTAUTH_SECRET=your-super-secret-nextauth-key-here  # [REQUIRED]

# Google OAuth (Phase 2+)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# PAYMENTS — Razorpay
# Docs: https://razorpay.com/docs/payments/server-integration/
# Use TEST keys for development, LIVE keys for production
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX            # [REQUIRED]
RAZORPAY_KEY_SECRET=your-razorpay-key-secret         # [REQUIRED]
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret # [REQUIRED]
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX  # [REQUIRED] — exposed to client

# -----------------------------------------------------------------------------
# EMAIL — Resend
# Docs: https://resend.com/docs
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # [REQUIRED]
RESEND_FROM_EMAIL=seva@vrindavanbhandara.com
RESEND_FROM_NAME="Vrindavan Bhandara"

# -----------------------------------------------------------------------------
# STORAGE — Cloudflare R2
# Docs: https://developers.cloudflare.com/r2/api/s3/api/
# -----------------------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id  # [REQUIRED]
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id    # [REQUIRED]
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key   # [REQUIRED]
CLOUDFLARE_R2_BUCKET_NAME=vrindavanbhandara-media     # [REQUIRED]
CLOUDFLARE_R2_PUBLIC_URL=https://media.vrindavanbhandara.com  # [REQUIRED]

# -----------------------------------------------------------------------------
# WHATSAPP — Meta Business API (Phase 1 architecture, Phase 2 live)
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-whatsapp-webhook-verify-token
WHATSAPP_API_VERSION=v19.0
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=+919999999999    # Displayed on site

# -----------------------------------------------------------------------------
# MONITORING — Sentry
# Docs: https://docs.sentry.io/platforms/javascript/guides/nextjs/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@sentry.io/PROJECT_ID
SENTRY_ORG=vrindavanbhandara
SENTRY_PROJECT=vrindavanbhandara-web
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# -----------------------------------------------------------------------------
# ANALYTICS — PostHog
# Docs: https://posthog.com/docs/libraries/next-js
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# RATE LIMITING — Upstash Redis (production)
# For development: falls back to in-memory rate limiter
# Docs: https://upstash.com/docs/redis/sdks/ratelimit-ts/overview
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# ADMIN — Initial super admin seed credentials
# Used only during `prisma db seed` — change immediately after first login
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@vrindavanbhandara.com
SEED_ADMIN_PASSWORD=ChangeMe@123!

# -----------------------------------------------------------------------------
# SEO & DOMAIN
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://vrindavanbhandara.com
NEXT_PUBLIC_SITE_NAME="Vrindavan Bhandara"
NEXT_PUBLIC_OG_IMAGE=https://vrindavanbhandara.com/og-image.jpg

# -----------------------------------------------------------------------------
# CRON / INTERNAL API
# Secret header for protecting internal cron job routes
# -----------------------------------------------------------------------------
CRON_SECRET=your-internal-cron-secret

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Phase 2/3 — toggle without redeployment)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FEATURE_REFERRAL=false
NEXT_PUBLIC_FEATURE_COUPONS=false
NEXT_PUBLIC_FEATURE_SUBSCRIPTIONS=false
NEXT_PUBLIC_FEATURE_WHATSAPP_LIVE=false
